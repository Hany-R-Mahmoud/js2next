{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://js2next.local/schemas/question.schema.v2.json",
  "title": "JS2Next Assessment Question v2",
  "type": "object",
  "required": [
    "id",
    "trackId",
    "moduleId",
    "topicId",
    "kind",
    "prompt",
    "choices",
    "correctChoiceIds",
    "explanation",
    "difficulty",
    "cognitiveLevel",
    "version",
    "status",
    "reviewStatus",
    "presentation",
    "assessmentMode",
    "practical",
    "assessmentPolicyVersion"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z0-9-]+$"
    },
    "trackId": {
      "enum": [
        "javascript",
        "react",
        "nextjs"
      ]
    },
    "moduleId": {
      "type": "string"
    },
    "topicId": {
      "type": "string"
    },
    "objectiveIds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "kind": {
      "const": "single-choice"
    },
    "presentation": {
      "enum": [
        "text",
        "code"
      ]
    },
    "prompt": {
      "type": "string",
      "minLength": 10
    },
    "code": {
      "type": "object",
      "required": [
        "language",
        "source"
      ],
      "properties": {
        "language": {
          "type": "string"
        },
        "source": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "choices": {
      "type": "array",
      "minItems": 3,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "feedback"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "feedback": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "correctChoiceIds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "explanation": {
      "type": "string",
      "minLength": 10
    },
    "hint": {
      "type": "string"
    },
    "difficulty": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "cognitiveLevel": {
      "enum": [
        "recognize",
        "explain",
        "predict",
        "apply",
        "debug",
        "tradeoff",
        "synthesize",
        "transfer"
      ]
    },
    "estimatedSeconds": {
      "type": "integer",
      "minimum": 10
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "enum": [
        "draft",
        "reviewed",
        "published",
        "retired"
      ]
    },
    "reviewStatus": {
      "enum": [
        "pending-human-review",
        "approved",
        "needs-revision"
      ]
    },
    "assessmentMode": {
      "enum": [
        "conceptual-review",
        "scenario-reasoning",
        "conceptual-comparison",
        "code-reading",
        "code-verification",
        "debugging",
        "code-analysis",
        "implementation-choice",
        "workflow-artifact",
        "workflow-scenario",
        "engineering-judgment",
        "architecture-tradeoff",
        "workflow-judgment",
        "conceptual-judgment"
      ]
    },
    "practical": {
      "type": "boolean"
    },
    "assessmentPolicyVersion": {
      "const": "2.0"
    }
  },
  "additionalProperties": true
}
