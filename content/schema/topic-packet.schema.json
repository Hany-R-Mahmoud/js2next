{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://js2next.local/schemas/topic-packet.schema.json",
  "title": "JS2Next Topic Packet",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "slug",
    "trackId",
    "moduleId",
    "order",
    "title",
    "learningObjectives",
    "sections",
    "questions",
    "topicQuiz",
    "version",
    "status",
    "reviewStatus",
    "publicationStatus"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "id": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "trackId": {
      "enum": [
        "javascript",
        "react",
        "nextjs"
      ]
    },
    "moduleId": {
      "type": "string"
    },
    "order": {
      "type": "integer",
      "minimum": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "required": {
      "type": "boolean"
    },
    "optional": {
      "type": "boolean"
    },
    "advanced": {
      "type": "boolean"
    },
    "contentType": {
      "type": "string"
    },
    "difficulty": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "estimatedMinutes": {
      "type": "integer",
      "minimum": 1
    },
    "requiredPrerequisiteTopicIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommendedPrerequisiteTopicIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "learningObjectives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "whyThisMatters": {
      "type": "string",
      "minLength": 10
    },
    "mentalModel": {
      "type": "string",
      "minLength": 10
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "commonMistakes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "inLessonQuestionIds": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string"
      }
    },
    "topicQuiz": {
      "type": "object",
      "required": [
        "id",
        "questionIds",
        "masteryThresholdPercent",
        "attemptPolicy"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "questionIds": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "string"
          }
        },
        "masteryThresholdPercent": {
          "const": 80
        },
        "attemptPolicy": {
          "const": "unlimited"
        }
      }
    },
    "assessmentProfile": {
      "type": "object",
      "required": [
        "version",
        "type",
        "label",
        "rationale",
        "topicQuizMix",
        "inLessonPolicy",
        "topicQuizPolicy"
      ],
      "properties": {
        "version": { "const": "2.0" },
        "type": { "enum": ["conceptual", "workflow", "hybrid", "coding"] },
        "label": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string", "minLength": 1 },
        "topicQuizMix": { "type": "object" },
        "inLessonPolicy": { "type": "string", "minLength": 1 },
        "topicQuizPolicy": { "type": "string", "minLength": 1 }
      }
    },
    "questions": {
      "type": "array",
      "minItems": 8,
      "items": {
        "$ref": "question.schema.v2.json"
      }
    },
    "researchSources": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "version": {
      "const": 2
    },
    "status": {
      "enum": [
        "draft",
        "reviewed",
        "published",
        "archived"
      ]
    },
    "reviewStatus": {
      "enum": [
        "pending-human-review",
        "approved",
        "needs-revision"
      ]
    },
    "publicationStatus": {
      "enum": [
        "unpublished",
        "published"
      ]
    }
  },
  "additionalProperties": true
}
