# Public Supabase browser and SSR configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# closed | preview | members. Production defaults to closed when omitted.
CONTENT_ACCESS_MODE=closed

# Required for CONTENT_ACCESS_MODE=members builds.
CONTENT_PRODUCTION_MANIFEST=

# Canonical URLs and SMTP are configured in Vercel and Supabase, not committed here.
NEXT_PUBLIC_SITE_URL=https://your-production-domain.example

