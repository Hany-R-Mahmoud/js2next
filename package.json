{
  "name": "learn-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run validate:production-content && next build",
    "start": "next start",
    "lint": "eslint src --max-warnings=0",
    "test": "vitest run",
    "audit:content": "node scripts/content-audit-report.mjs",
    "validate:release-1": "node --experimental-strip-types scripts/validate-release-1.ts",
    "validate:assessment-v2": "node --experimental-strip-types scripts/validate-assessment-v2.ts",
    "validate:production-content": "node --experimental-strip-types scripts/validate-production-content.ts",
    "e2e:release-1": "node scripts/release-1-smoke.mjs",
    "verify:sources": "LIVE_SOURCE_CHECK=1 vitest run src/lib/content/source-links.live.test.ts",
    "test:watch": "vitest",
    "typecheck": "next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.5.3",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.8",
    "@vercel/analytics": "^2.0.1",
    "ky": "^2.0.2",
    "next": "15.5.21",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.0.0",
    "eslint-config-next": "15.5.21",
    "postcss": "8.5.19",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "8.5.19",
    "sharp": "0.35.0"
  }
}
