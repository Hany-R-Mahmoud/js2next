{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://js2next.local/schemas/curriculum.schema.json",
  "title": "JS2Next Curriculum Runtime",
  "type": "object",
  "required": [
    "schemaVersion",
    "product",
    "release",
    "tracks",
    "prerequisiteEdges",
    "assessmentPolicy"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "product": {
      "const": "JS2Next"
    },
    "release": {
      "const": "Release 1"
    },
    "tracks": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "order",
          "modules"
        ],
        "properties": {
          "id": {
            "enum": [
              "javascript",
              "react",
              "nextjs"
            ]
          },
          "title": {
            "type": "string"
          },
          "order": {
            "type": "integer"
          },
          "modules": {
            "type": "array",
            "minItems": 1
          }
        }
      }
    },
    "prerequisiteEdges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "fromTopicId",
          "toTopicId",
          "kind"
        ]
      }
    },
    "assessmentPolicy": {
      "type": "object"
    }
  },
  "additionalProperties": true
}